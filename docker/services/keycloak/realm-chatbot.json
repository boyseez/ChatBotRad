      {
        "name": "ROLE_USER",
        "description": "Standard user role"
      },
      {
        "name": "ROLE_ADMIN",
        "description": "Administrator role"
      }
    ]
  },
  "clients": [
    {
      "clientId": "chatbot-backend",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
